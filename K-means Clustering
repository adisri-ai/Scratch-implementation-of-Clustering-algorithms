   "source": [
    "costs = []\n",
    "for i in range(2 , 9):\n",
    "    kmc = KMeansClustering(data)\n",
    "    labels , centroids = kmc.solve(i)\n",
    "    costs.append(kmc.eval(labels , centroids))\n",
    "plt.plot(range(2, 9), costs)\n",
    "plt.xlabel(\"k\")\n",
    "plt.ylabel(\"Average distance from centroid\")\n",
    "plt.title(\"Elbow Curve\")\n",
    "plt.show()"
   ]
